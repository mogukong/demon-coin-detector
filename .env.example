# Binance API Configuration
# Get from: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Telegram Bot Configuration (Optional)
# Get token from: @BotFather on Telegram
# Get chat_id from: @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Proxy Configuration (Optional)
# Required for Telegram in some regions
TELEGRAM_PROXY=http://127.0.0.1:3067

# Trading Configuration (Optional - defaults in strategy_params.json)
# LEVERAGE=10
# MAX_POSITIONS=3
# DAILY_LOSS_LIMIT=0.30
